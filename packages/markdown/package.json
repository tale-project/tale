{
  "name": "@tale/markdown",
  "version": "0.1.0",
  "private": true,
  "description": "Tale shared markdown rendering pipeline — components, plugins, streaming primitives. The single source for every markdown surface in web, docs, and platform.",
  "type": "module",
  "exports": {
    "./markdown": "./src/markdown.tsx",
    "./routed-markdown": "./src/routed-markdown.tsx",
    "./shiki": "./src/shiki.ts",
    "./code-block": "./src/code-block.tsx",
    "./anchored-heading": "./src/anchored-heading.tsx",
    "./extract-toc": "./src/extract-toc.ts",
    "./reading-time": "./src/reading-time.ts",
    "./components/callout": "./src/components/callout.tsx",
    "./components/code-group": "./src/components/code-group.tsx",
    "./components/tabs": "./src/components/tabs.tsx",
    "./components/steps": "./src/components/steps.tsx",
    "./components/cards": "./src/components/cards.tsx",
    "./components/frame": "./src/components/frame.tsx",
    "./components/accordion": "./src/components/accordion.tsx",
    "./components/mermaid": "./src/components/mermaid.tsx",
    "./components/registry": "./src/components/registry.tsx",
    "./streaming/incremental-markdown": "./src/streaming/incremental-markdown.tsx",
    "./streaming/remend-markdown": "./src/streaming/remend-markdown.ts",
    "./streaming/normalize-html-blocks": "./src/streaming/normalize-html-blocks.ts",
    "./streaming/find-block-split": "./src/streaming/find-block-split.ts",
    "./plugins/micromark-cjk-attention": "./src/plugins/micromark-cjk-attention.ts",
    "./types": "./src/types.ts",
    "./globals.css": "./src/globals.css"
  },
  "scripts": {
    "lint": "bunx oxlint --type-aware",
    "lint:fix": "bunx oxlint --type-aware --fix",
    "typecheck": "bunx tsc --noEmit",
    "test": "bunx vitest --run --passWithNoTests",
    "test:watch": "bunx vitest",
    "storybook": "bunx --bun storybook dev -p 6008",
    "storybook:build": "bunx --bun storybook build -o storybook-static"
  },
  "dependencies": {
    "@tale/ui": "workspace:*",
    "@tanstack/react-router": "1.168.10",
    "lucide-react": "1.8.0",
    "mermaid": "11.14.0",
    "micromark": "4.0.2",
    "micromark-core-commonmark": "2.0.3",
    "micromark-util-classify-character": "2.0.1",
    "micromark-util-types": "2.0.2",
    "react-markdown": "10.1.0",
    "rehype-raw": "7.0.0",
    "rehype-sanitize": "6.0.0",
    "remark-gfm": "4.0.1",
    "shiki": "3.2.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*"
  }
}
