{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["dom", "es2023"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "incremental": true,
    "resolveJsonModule": true,
    "types": ["vitest/globals", "@types/bun"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "test/fixtures/**", "datasets/**"]
}
