{
  "name": "@tale/pii",
  "version": "0.1.0",
  "private": true,
  "description": "Multilingual PII detection, masking, and scrubbing — offline-only, plugin-friendly, locale-aware",
  "files": [
    "src/**/*.ts",
    "src/**/*.json",
    "README.md",
    "LICENSES.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./engine": "./src/engine/index.ts",
    "./engine/detector": "./src/engine/detector.ts",
    "./engine/masker": "./src/engine/masker.ts",
    "./engine/scrubber": "./src/engine/scrubber.ts",
    "./engine/registry": "./src/engine/registry.ts",
    "./patterns": "./src/patterns/index.ts",
    "./locales": "./src/locales/index.ts",
    "./schemas": "./src/schemas/config.ts",
    "./core/outcome": "./src/core/outcome.ts",
    "./core/regex-safety": "./src/core/regex-safety.ts",
    "./core/normalize": "./src/core/normalize.ts",
    "./core/types": "./src/core/types.ts"
  },
  "scripts": {
    "lint": "bunx oxlint --type-aware",
    "lint:fix": "bunx oxlint --type-aware --fix",
    "typecheck": "bunx tsc --noEmit",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "fixtures:gen": "bun scripts/gen/index.ts",
    "fixtures:refresh": "bun scripts/refresh/index.ts",
    "fixtures:verify": "bun scripts/gen/index.ts verify"
  },
  "dependencies": {
    "libphonenumber-js": "1.12.42",
    "safe-regex2": "5.1.1",
    "validator": "13.15.35",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/seedrandom": "3.0.8",
    "@types/validator": "13.15.10",
    "seedrandom": "3.0.5"
  }
}
