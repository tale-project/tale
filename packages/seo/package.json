{
  "name": "@tale/seo",
  "version": "0.2.0",
  "private": true,
  "description": "Build-time SEO + LLM artifact helpers (llms.txt, sitemap, robots.txt, JSON-LD, HTML → Markdown). Pure Node, no React.",
  "bin": {
    "tale-seo-compile": "./bin/compile.ts"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./builders/llms-txt": "./src/builders/llms-txt.ts",
    "./builders/llms-full-txt": "./src/builders/llms-full-txt.ts",
    "./builders/sitemap": "./src/builders/sitemap.ts",
    "./builders/robots": "./src/builders/robots.ts",
    "./builders/json-ld": "./src/builders/json-ld.ts",
    "./builders/page-as-markdown": "./src/builders/page-as-markdown.ts",
    "./builders/md-paths": "./src/builders/md-paths.ts",
    "./transform/html-to-markdown": "./src/transform/html-to-markdown.ts",
    "./plugins/default": "./src/plugins/default.ts",
    "./plugins/llms-txt": "./src/plugins/llms-txt.ts",
    "./plugins/llms-full-txt": "./src/plugins/llms-full-txt.ts",
    "./plugins/sitemap": "./src/plugins/sitemap.ts",
    "./plugins/robots": "./src/plugins/robots.ts",
    "./plugins/page-markdown": "./src/plugins/page-markdown.ts",
    "./runtime/plugin": "./src/runtime/plugin.ts",
    "./runtime/etag": "./src/runtime/etag.ts",
    "./runtime/cache": "./src/runtime/cache.ts",
    "./runtime/compile": "./src/runtime/compile.ts",
    "./runtime/manifest": "./src/runtime/manifest.ts",
    "./runtime/on-demand-server": "./src/runtime/on-demand-server.ts",
    "./runtime/precompiled-server": "./src/runtime/precompiled-server.ts",
    "./vite-plugin-artifacts": "./src/runtime/vite-plugin.ts",
    "./globals": "./src/globals.ts",
    "./bin/compile": "./bin/compile.ts"
  },
  "scripts": {
    "lint": "bunx oxlint --type-aware",
    "lint:fix": "bunx oxlint --type-aware --fix",
    "typecheck": "bunx tsc --noEmit",
    "test": "bunx vitest --run",
    "test:watch": "bunx vitest"
  },
  "dependencies": {
    "@tale/i18n": "workspace:*",
    "jsdom": "29.0.2"
  },
  "peerDependencies": {
    "vite": "*"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
