{
  "name": "@tale/webui",
  "version": "0.1.0",
  "private": true,
  "description": "Shared web/docs layout, search, SEO + LLM helpers (markdown pipeline lives in @tale/ui/markdown)",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./layout/site-container": "./src/layout/site-container.tsx",
    "./layout/site-header": "./src/layout/site-header.tsx",
    "./layout/site-footer": "./src/layout/site-footer.tsx",
    "./layout/external-link": "./src/layout/external-link.tsx",
    "./layout/skip-link": "./src/layout/skip-link.tsx",
    "./layout/language-switcher": "./src/layout/language-switcher.tsx",
    "./layout/theme-switcher": "./src/layout/theme-switcher.tsx",
    "./icons/flags": "./src/icons/flags.tsx",
    "./seo/document-meta": "./src/seo/document-meta.ts",
    "./seo/build-sitemap": "./src/seo/build-sitemap.ts",
    "./seo/build-robots": "./src/seo/build-robots.ts",
    "./seo/json-ld": "./src/seo/json-ld.ts",
    "./llm/build-llms-txt": "./src/llm/build-llms-txt.ts",
    "./llm/build-llms-full-txt": "./src/llm/build-llms-full-txt.ts",
    "./llm/page-as-markdown": "./src/llm/page-as-markdown.ts",
    "./search/dialog": "./src/search/dialog.tsx",
    "./search/build-index": "./src/search/build-index.ts",
    "./search/client": "./src/search/client.ts",
    "./search/snippet": "./src/search/snippet.ts",
    "./search/highlight": "./src/search/highlight.tsx",
    "./search/recent-searches": "./src/search/recent-searches.ts",
    "./search/use-search": "./src/search/use-search.ts",
    "./search/types": "./src/search/types.ts",
    "./ai/page-actions": "./src/ai/page-actions.tsx",
    "./theme": "./src/theme/index.ts",
    "./hooks/use-debounce": "./src/hooks/use-debounce.ts",
    "./hooks/use-dropdown-placement": "./src/hooks/use-dropdown-placement.ts",
    "./utils/parse-frontmatter": "./src/utils/parse-frontmatter.ts",
    "./globals.css": "./src/globals.css",
    "./tailwind-preset": "./tailwind-preset.ts"
  },
  "scripts": {
    "lint": "bunx oxlint --type-aware",
    "lint:fix": "bunx oxlint --type-aware --fix",
    "typecheck": "bunx tsc --noEmit",
    "test": "bunx vitest --run --project unit --passWithNoTests",
    "test:watch": "bunx vitest",
    "test:storybook": "bunx vitest --run --project storybook",
    "storybook": "bunx --bun storybook dev -p 6007",
    "storybook:build": "bunx --bun storybook build -o storybook-static"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.15",
    "@tale/i18n": "workspace:*",
    "@tale/ui": "workspace:*",
    "@tanstack/react-router": "1.168.10",
    "framer-motion": "12.38.0",
    "lucide-react": "1.8.0",
    "minisearch": "7.2.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*"
  }
}
