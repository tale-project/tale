{
  "workflowConfig": {
    "name": "Product Relationship Analysis",
    "description": "Analyze product relationships based on customer subscription patterns using AI",
    "version": "2.0.0",
    "workflowType": "predefined",
    "config": {
      "timeout": 1800000,
      "retryPolicy": { "maxRetries": 2, "backoffMs": 5000 },
      "variables": {
        "organizationId": "org_demo",
        "workflowId": "product-relationship-analysis",
        "backoffHours": 168,
        "analysisVersion": "2.0"
      }
    }
  },
  "stepsConfig": [
    {
      "stepSlug": "start",
      "name": "start",
      "stepType": "start",
      "config": {},
      "nextSteps": { "success": "find_unprocessed_product" }
    },
    {
      "stepSlug": "find_unprocessed_product",
      "name": "Find One Unprocessed Product",
      "stepType": "action",
      "config": {
        "type": "workflow_processing_records",
        "parameters": {
          "operation": "find_unprocessed",
          "tableName": "products",
          "backoffHours": "{{backoffHours}}"
        }
      },
      "nextSteps": {
        "success": "check_has_product"
      }
    },
    {
      "stepSlug": "check_has_product",
      "name": "Check if Product Found",
      "stepType": "condition",
      "config": {
        "expression": "steps.find_unprocessed_product.output.data != null",
        "description": "Check if we found an unprocessed product"
      },
      "nextSteps": {
        "true": "extract_product_data",
        "false": "noop"
      }
    },
    {
      "stepSlug": "extract_product_data",
      "name": "Extract Product Data and Shop Variant IDs",
      "stepType": "action",
      "config": {
        "type": "set_variables",
        "parameters": {
          "variables": [
            {
              "name": "sourceProduct",
              "value": "{{steps.find_unprocessed_product.output.data}}"
            },
            {
              "name": "sourceProductId",
              "value": "{{steps.find_unprocessed_product.output.data._id}}"
            },
            {
              "name": "sourceProductName",
              "value": "{{steps.find_unprocessed_product.output.data.name}}"
            },
            {
              "name": "shopVariantIds",
              "value": "{{steps.find_unprocessed_product.output.data.metadata.circuly.variants|map('shop_variant_id')|unique}}"
            },
            {
              "name": "analysisTimestamp",
              "value": "{{now}}"
            }
          ]
        }
      },
      "nextSteps": {
        "success": "filter_customers_by_subscriptions"
      }
    },
    {
      "stepSlug": "filter_customers_by_subscriptions",
      "name": "Filter Customers with Matching Subscriptions",
      "stepType": "action",
      "config": {
        "type": "customer",
        "parameters": {
          "operation": "filter",
          "expression": "(metadata && metadata.subscriptions && metadata.subscriptions.data) ? metadata.subscriptions.data|map('product_id')|hasOverlap({{shopVariantIds}}) : false"
        }
      },
      "nextSteps": {
        "success": "check_has_customers"
      }
    },
    {
      "stepSlug": "check_has_customers",
      "name": "Check if Customers Found",
      "stepType": "condition",
      "config": {
        "expression": "steps.filter_customers_by_subscriptions.output.data|length > 0",
        "description": "Check if we found any customers with matching subscriptions"
      },
      "nextSteps": {
        "true": "extract_customer_product_ids",
        "false": "record_processed"
      }
    },
    {
      "stepSlug": "extract_customer_product_ids",
      "name": "Extract All Product IDs from Customer Subscriptions",
      "stepType": "action",
      "config": {
        "type": "set_variables",
        "parameters": {
          "variables": [
            {
              "name": "customerProductIds",
              "value": "{{steps.filter_customers_by_subscriptions.output.data|map('metadata.subscriptions.data')|flatten|map('product_id')|unique}}"
            }
          ]
        }
      },
      "nextSteps": {
        "success": "filter_related_products"
      }
    },
    {
      "stepSlug": "filter_related_products",
      "name": "Filter Products with Overlapping Variant IDs",
      "stepType": "action",
      "config": {
        "type": "product",
        "parameters": {
          "operation": "filter",
          "expression": "(metadata && metadata.circuly && metadata.circuly.variants) ? metadata.circuly.variants|map('shop_variant_id')|hasOverlap({{customerProductIds}}) : false"
        }
      },
      "nextSteps": {
        "success": "prepare_ai_analysis"
      }
    },
    {
      "stepSlug": "prepare_ai_analysis",
      "name": "Prepare AI Analysis Prompt",
      "stepType": "action",
      "config": {
        "type": "set_variables",
        "parameters": {
          "variables": [
            {
              "name": "allProducts",
              "value": "{{[sourceProduct]|concat(steps.filter_related_products.output.data)}}"
            },
            {
              "name": "productList",
              "value": "{{allProducts|formatList(\"Product ID: {_id}\\nName: {name}\\nCategory: {category}\\nPrice: \\u20ac{price}/month\\nDescription: {description}\\nShop Variant IDs: {metadata.circuly.variants|map('shop_variant_id')|join(', ')}\", \"\\n\\n---\\n\\n\")}}"
            },
            {
              "name": "aiPrompt",
              "value": "TASK: Analyze the relationships between products based on customer subscription patterns.\n\nSOURCE PRODUCT (the product we're analyzing):\nProduct ID: {{sourceProductId}}\nName: {{sourceProductName}}\n\nRELATED PRODUCTS (products that customers subscribe to alongside the source product):\n\n{{productList}}\n\n---\n\nCONTEXT: These products are related because customers who subscribe to the source product also subscribe to these related products. We want to understand the nature of these relationships.\n\nINSTRUCTIONS:\n1. Analyze the relationship between the SOURCE PRODUCT and EACH related product\n2. Classify relationships as:\n   - Complementary: Products that work well together (e.g., stroller + car seat)\n   - Substitute: Alternative products serving similar needs (e.g., different stroller models)\n   - Bundle: Products typically sold together as a package\n   - Upgrade: Products representing different tiers/versions (e.g., basic vs premium)\n3. ONLY include products that have a meaningful relationship (Complementary, Substitute, Bundle, or Upgrade)\n4. DO NOT include products with \"None\" relationship type - simply omit them from the results\n\n5. Return results in JSON format:\n{\n  \"relationships\": [\n    {\n      \"source_product_id\": \"SOURCE_PRODUCT_ID\",\n      \"target_product_id\": \"RELATED_PRODUCT_ID\",\n      \"relationship_type\": \"Complementary|Substitute|Bundle|Upgrade\",\n      \"confidence\": 0.8,\n      \"reasoning\": \"Brief explanation of why these products are related\"\n    }\n  ]\n}\n\nIMPORTANT:\n- Use the exact Product ID values from the list above (they start with \"j\" or \"k\"). These are Convex document IDs.\n- Only create relationships between the SOURCE PRODUCT ({{sourceProductId}}) and the related products.\n- Do NOT create relationships between related products themselves.\n- source_product_id should always be {{sourceProductId}}\n- target_product_id should be the ID of each related product\n\nBIDIRECTIONAL RELATIONSHIPS:\n- For Complementary, Substitute, and Bundle relationships, you MUST create BOTH directions:\n  * One relationship from SOURCE to TARGET\n  * One relationship from TARGET to SOURCE (with source and target swapped)\n- For Upgrade relationships, only create ONE direction (from lower tier to higher tier)\n- For None relationships, DO NOT create any relationship entry at all (skip it entirely)\n- Example for Complementary relationship between Product A and Product B:\n  [\n    {\n      \"source_product_id\": \"A\",\n      \"target_product_id\": \"B\",\n      \"relationship_type\": \"Complementary\",\n      \"confidence\": 0.8,\n      \"reasoning\": \"Product A works well with Product B\"\n    },\n    {\n      \"source_product_id\": \"B\",\n      \"target_product_id\": \"A\",\n      \"relationship_type\": \"Complementary\",\n      \"confidence\": 0.8,\n      \"reasoning\": \"Product B works well with Product A\"\n    }\n  ]"
            }
          ]
        }
      },
      "nextSteps": {
        "success": "analyze_product_relationships"
      }
    },
    {
      "stepSlug": "analyze_product_relationships",
      "name": "AI Analyze Product Relationships",
      "stepType": "llm",
      "config": {
        "name": "Product Relationship Analyzer",
        "userPrompt": "{{aiPrompt}}",
        "systemPrompt": "You are an expert product analyst specializing in subscription-based product relationships. Analyze product relationships based on actual customer subscription patterns. Always return valid JSON format as specified. Focus on practical business relationships that would be useful for recommendations and cross-selling. CRITICAL: For Complementary, Substitute, and Bundle relationships, you MUST create bidirectional relationships (both A→B and B→A). For Upgrade relationships, only create unidirectional relationships (lower→higher tier). DO NOT include products with no meaningful relationship - simply omit them from the results.",
        "outputFormat": "json",
        "outputSchema": {
          "type": "object",
          "properties": {
            "relationships": {
              "type": "array",
              "description": "List of product relationships (empty array if no meaningful relationships)",
              "items": {
                "type": "object",
                "properties": {
                  "source_product_id": {
                    "type": "string",
                    "description": "Convex ID of the source product"
                  },
                  "target_product_id": {
                    "type": "string",
                    "description": "Convex ID of the target product"
                  },
                  "relationship_type": {
                    "type": "string",
                    "enum": ["Complementary", "Substitute", "Bundle", "Upgrade"],
                    "description": "Type of relationship between products"
                  },
                  "confidence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "description": "Confidence score for the relationship"
                  },
                  "reasoning": {
                    "type": "string",
                    "description": "Brief explanation of why these products are related"
                  }
                },
                "required": [
                  "source_product_id",
                  "target_product_id",
                  "relationship_type",
                  "confidence",
                  "reasoning"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": ["relationships"],
          "additionalProperties": false
        }
      },
      "nextSteps": {
        "success": "check_has_relationships"
      }
    },
    {
      "stepSlug": "check_has_relationships",
      "name": "Check if Relationships Found",
      "stepType": "condition",
      "config": {
        "expression": "steps.analyze_product_relationships.output.data.relationships|length > 0",
        "description": "Check if AI found any relationships"
      },
      "nextSteps": {
        "true": "loop_relationships",
        "false": "record_processed"
      }
    },
    {
      "stepSlug": "loop_relationships",
      "name": "Loop Through Relationships",
      "stepType": "loop",
      "config": {
        "items": "{{steps.analyze_product_relationships.output.data.relationships}}",
        "itemVariable": "item"
      },
      "nextSteps": {
        "loop": "query_product_for_update",
        "done": "record_processed"
      }
    },
    {
      "stepSlug": "query_product_for_update",
      "name": "Query Product for Update",
      "stepType": "action",
      "config": {
        "type": "product",
        "parameters": {
          "operation": "get_by_id",
          "productId": "{{loop.item.source_product_id}}"
        }
      },
      "nextSteps": {
        "success": "check_relationship_exists"
      }
    },
    {
      "stepSlug": "check_relationship_exists",
      "name": "Check if Relationship Already Exists",
      "stepType": "condition",
      "config": {
        "expression": "(steps.query_product_for_update.output.data && steps.query_product_for_update.output.data.metadata && steps.query_product_for_update.output.data.metadata.relationships) ? (steps.query_product_for_update.output.data.metadata.relationships|find('productId', loop.item.target_product_id) != null) : false",
        "description": "Check if relationship with target product already exists in metadata"
      },
      "nextSteps": {
        "true": "loop_relationships",
        "false": "prepare_updated_relationships"
      }
    },
    {
      "stepSlug": "prepare_updated_relationships",
      "name": "Prepare Updated Relationships Array",
      "stepType": "action",
      "config": {
        "type": "set_variables",
        "parameters": {
          "variables": [
            {
              "name": "existingRelationships",
              "value": "{{(steps.query_product_for_update.output.data && steps.query_product_for_update.output.data.metadata && steps.query_product_for_update.output.data.metadata.relationships) ? steps.query_product_for_update.output.data.metadata.relationships : []}}"
            },
            {
              "name": "newRelationship",
              "value": {
                "productId": "{{loop.item.target_product_id}}",
                "productName": "{{allProducts|find(\"_id\", loop.item.target_product_id).name}}",
                "relationship_type": "{{loop.item.relationship_type}}",
                "confidence": "{{loop.item.confidence}}",
                "reasoning": "{{loop.item.reasoning}}"
              }
            },
            {
              "name": "updatedRelationships",
              "value": "{{existingRelationships|concat([newRelationship])}}"
            }
          ]
        }
      },
      "nextSteps": {
        "success": "update_product_metadata"
      }
    },
    {
      "stepSlug": "update_product_metadata",
      "name": "Update Product Metadata",
      "stepType": "action",
      "config": {
        "type": "product",
        "parameters": {
          "operation": "update",
          "productId": "{{loop.item.source_product_id}}",
          "updates": {
            "metadata": {
              "relationships": "{{updatedRelationships}}"
            }
          }
        }
      },
      "nextSteps": {
        "success": "loop_relationships"
      }
    },
    {
      "stepSlug": "record_processed",
      "name": "Record Product as Processed",
      "stepType": "action",
      "config": {
        "type": "workflow_processing_records",
        "parameters": {
          "operation": "record_processed",
          "tableName": "products",
          "recordId": "{{sourceProductId}}",
          "metadata": {
            "relationshipsFound": "{{steps.analyze_product_relationships.output.data.relationships|length}}",
            "analyzedAt": "{{analysisTimestamp}}"
          }
        }
      },
      "nextSteps": {
        "success": "noop"
      }
    }
  ]
}
