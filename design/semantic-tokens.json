        "300": { "value": "#6FE6A7" },
        "400": { "value": "#36D183" },
        "500": { "value": "#12B76A" },
        "600": { "value": "#079455" },
        "700": { "value": "#057747" },
        "800": { "value": "#075E3A" },
        "900": { "value": "#074D32" },
        "950": { "value": "#022C1C" }
      },
      "info": {
        "25":  { "value": "#F4F9FF" },
        "50":  { "value": "#EFF6FF" },
        "100": { "value": "#DBEAFE" },
        "200": { "value": "#BFDBFE" },
        "300": { "value": "#93C5FD" },
        "400": { "value": "#60A5FA" },
        "500": { "value": "#3B82F6" },
        "600": { "value": "#2563EB" },
        "700": { "value": "#1D4ED8" },
        "800": { "value": "#1E40AF" },
        "900": { "value": "#1E3A8A" },
        "950": { "value": "#172554" }
      },
      "black": {
        "25":  { "value": "#FDFEFE" },
        "50":  { "value": "#F5F8F8" },
        "100": { "value": "#DEE7E9" },
        "200": { "value": "#BCD0D3" },
        "300": { "value": "#93AFB5" },
        "400": { "value": "#6D8B94" },
        "500": { "value": "#536F79" },
        "600": { "value": "#405861" },
        "700": { "value": "#36484F" },
        "800": { "value": "#2E3C41" },
        "900": { "value": "#2A3237" },
        "950": { "value": "#060809" }
      },
      "white": {
        "50":  { "value": "#FFFFFF" },
        "100": { "value": "#EFEFEF" },
        "200": { "value": "#DCDCDC" },
        "300": { "value": "#BDBDBD" },
        "400": { "value": "#989898" },
        "500": { "value": "#7C7C7C" },
        "600": { "value": "#656565" },
        "700": { "value": "#525252" },
        "800": { "value": "#464646" },
        "900": { "value": "#3D3D3D" },
        "950": { "value": "#292929" }
      }
    }
  },

  "semantic": {
    "color": {

      "background": {
        "$description": "Page and section backgrounds",
        "default":    { "light": "#FFFFFF",   "dark": "#0A0A0A" },
        "primary":    { "light": "#FFFFFF",   "dark": "#030712" },
        "secondary":  { "light": "#F9FAFB",   "dark": "#111827" },
        "tertiary":   { "light": "#F3F4F6",   "dark": "#1F2937" },
        "brand":      { "light": "#056CFF",   "dark": "#056CFF" },
        "brandSubtle":{ "light": "#F3F8FF",   "dark": "#02204D" },
        "disabled":   { "light": "#F3F4F6",   "dark": "#1F2937" },
        "inverse":    { "light": "#030712",   "dark": "#FFFFFF" },
        "overlay":    { "light": "#11182780", "dark": "#00000080" }
      },

      "surface": {
        "$description": "Card and container surfaces",
        "primary":   { "light": "#FFFFFF",  "dark": "#111827" },
        "secondary": { "light": "#F9FAFB",  "dark": "#1F2937" },
        "elevated":  { "light": "#FFFFFF",  "dark": "#1F2937" },
        "sunken":    { "light": "#F3F4F6",  "dark": "#030712" }
      },

      "text": {
        "$description": "Typography colors",
        "primary":     { "light": "#030712",  "dark": "#F9FAFB" },
        "secondary":   { "light": "#374151",  "dark": "#D1D5DB" },
        "tertiary":    { "light": "#6B7280",  "dark": "#9CA3AF" },
        "brand":       { "light": "#056CFF",  "dark": "#5098FF" },
        "disabled":    { "light": "#D1D5DB",  "dark": "#4B5563" },
        "inverse":     { "light": "#FFFFFF",  "dark": "#030712" },
        "link":        { "light": "#056CFF",  "dark": "#9BC4FF" },
        "onColor":     { "light": "#FFFFFF",  "dark": "#FFFFFF" },
        "placeholder": { "light": "#9CA3AF",  "dark": "#6B7280" }
      },

      "border": {
        "$description": "Stroke and divider colors",
        "primary":   { "light": "#E5E7EB",  "dark": "#374151" },
        "secondary": { "light": "#D1D5DB",  "dark": "#4B5563" },
        "tertiary":  { "light": "#F3F4F6",  "dark": "#1F2937" },
        "brand":     { "light": "#056CFF",  "dark": "#5098FF" },
        "disabled":  { "light": "#E5E7EB",  "dark": "#1F2937" },
        "focus":     { "light": "#056CFF",  "dark": "#5098FF" },
        "error":     { "light": "#EF4444",  "dark": "#F87171" },
        "success":   { "light": "#12B76A",  "dark": "#36D183" },
        "warning":   { "light": "#F79009",  "dark": "#FDB322" }
      },

      "divider": {
        "$description": "Horizontal/vertical line separators",
        "default": { "light": "#E5E7EB", "dark": "#1F2937" }
      },

      "button": {
        "$description": "Button variant colors",
        "primary": {
          "bg":        { "light": "#056CFF",  "dark": "#056CFF" },
          "bgHover":   { "light": "#0561E6",  "dark": "#5098FF" },
          "text":      { "light": "#FFFFFF",  "dark": "#FFFFFF" }
        },
        "secondary": {
          "bg":        { "light": "#FFFFFF",  "dark": "#1F2937" },
          "bgHover":   { "light": "#F9FAFB",  "dark": "#374151" },
          "border":    { "light": "#D1D5DB",  "dark": "#4B5563" },
          "text":      { "light": "#374151",  "dark": "#F3F4F6" }
        },
        "danger": {
          "bg":        { "light": "#EF4444",  "dark": "#DC2626" },
          "bgHover":   { "light": "#DC2626",  "dark": "#EF4444" },
          "text":      { "light": "#FFFFFF",  "dark": "#FFFFFF" }
        },
        "ghost": {
          "bgHover":   { "light": "#F3F4F6",  "dark": "#1F2937" },
          "text":      { "light": "#6B7280",  "dark": "#9CA3AF" }
        },
        "disabled": {
          "$description": "Disabled state — applies to all button variants",
          "bg":    { "light": "#F3F4F6",   "dark": "#1F2937" },
          "text":  { "light": "#D1D5DB",   "dark": "#4B5563" }
        }
      },

      "input": {
        "$description": "Form input field colors",
        "bg":            { "light": "#FFFFFF",  "dark": "#111827" },
        "border":        { "light": "#D1D5DB",  "dark": "#4B5563" },
        "borderHover":   { "light": "#9CA3AF",  "dark": "#6B7280" },
        "borderFocus":   { "light": "#056CFF",  "dark": "#5098FF" },
        "label":         { "light": "#374151",  "dark": "#D1D5DB" },
        "text":          { "light": "#030712",  "dark": "#F9FAFB" },
        "placeholder":   { "light": "#9CA3AF",  "dark": "#6B7280" }
      },

      "card": {
        "$description": "Card component colors",
        "bg":     { "light": "#FFFFFF",  "dark": "#111827" },
        "border": { "light": "#E5E7EB",  "dark": "#1F2937" }
      },

      "nav": {
        "$description": "Navigation bar / sidebar",
        "bg":         { "light": "#FFFFFF",  "dark": "#030712" },
        "border":     { "light": "#E5E7EB",  "dark": "#1F2937" },
        "text":       { "light": "#6B7280",  "dark": "#9CA3AF" },
        "textActive": { "light": "#030712",  "dark": "#F9FAFB" }
      },

      "interactive": {
        "$description": "Generic interactive element states",
        "hover":    { "light": "#F3F4F6",  "dark": "#1F2937" },
        "active":   { "light": "#E5E7EB",  "dark": "#374151" },
        "selected": { "light": "#F3F8FF",  "dark": "#02204D" }
      },

      "feedback": {
        "$description": "Alert / toast / banner feedback colors",
        "error": {
          "bg":     { "light": "#FEF2F2",  "dark": "#450A0A" },
          "border": { "light": "#FECACA",  "dark": "#881C14" },
          "icon":   { "light": "#EF4444",  "dark": "#F87171" },
          "text":   { "light": "#B91C1C",  "dark": "#FCA5A5" }
        },
        "warning": {
          "bg":     { "light": "#FFFAEB",  "dark": "#461602" },
          "border": { "light": "#FEE089",  "dark": "#792E0E" },
          "icon":   { "light": "#F79009",  "dark": "#FDB322" },
          "text":   { "light": "#B54808",  "dark": "#FDC94C" }
        },
        "success": {
          "bg":     { "light": "#ECFDF3",  "dark": "#022C1C" },
          "border": { "light": "#A8F2C6",  "dark": "#074D32" },
          "icon":   { "light": "#12B76A",  "dark": "#36D183" },
          "text":   { "light": "#057747",  "dark": "#6FE6A7" }
        },
        "info": {
          "bg":     { "light": "#EFF6FF",  "dark": "#172554" },
          "border": { "light": "#BFDBFE",  "dark": "#1E3A8A" },
          "icon":   { "light": "#3B82F6",  "dark": "#60A5FA" },
          "text":   { "light": "#1D4ED8",  "dark": "#93C5FD" }
        }
      },

      "avatar": {
        "bg":   { "light": "#E6F0FF",  "dark": "#02204D" },
        "text": { "light": "#056CFF",  "dark": "#5098FF" }
      },

      "badge": {
        "brand": {
          "bg":   { "light": "#E6F0FF",  "dark": "#02204D" },
          "text": { "light": "#034199",  "dark": "#9BC4FF" }
        },
        "gray": {
          "bg":   { "light": "#F3F4F6",  "dark": "#374151" },
          "text": { "light": "#374151",  "dark": "#D1D5DB" }
        }
      },

      "tooltip": {
        "bg":   { "light": "#111827",  "dark": "#F9FAFB" },
        "text": { "light": "#FFFFFF",  "dark": "#030712" }
      },

      "skeleton": {
        "default": { "light": "#F3F4F6",  "dark": "#1F2937" }
      },

      "logo": {
        "default": { "light": "#060809",  "dark": "#FFFFFF" }
      }
    },

    "spacing": {
      "$description": "Consistent spacing scale",
      "2xs":     { "value": 4 },
      "4xs":     { "value": 6 },
      "xs":      { "value": 8 },
      "sm":      { "value": 12 },
      "md":      { "value": 16 },
      "mdPlus":  { "value": 20 },
      "lg":      { "value": 24 },
      "xl":      { "value": 32 },
      "2xl":     { "value": 40 },
      "3xl":     { "value": 48 },
      "4xl":     { "value": 64 },
      "5xl":     { "value": 80 },
      "6xl":     { "value": 96 },
      "7xl":     { "value": 120 }
    },

    "radii": {
      "$description": "Border radius scale",
      "none": { "value": 0 },
      "xs":   { "value": 2 },
      "sm":   { "value": 4 },
      "md":   { "value": 8 },
      "lg":   { "value": 12 },
      "xl":   { "value": 16 },
      "2xl":  { "value": 24 },
      "3xl":  { "value": 32 },
      "full": { "value": 9999 }
    },

    "typography": {
      "$description": "Font size and weight tokens",
      "fontSize": {
        "display":  { "value": 60 },
        "h1":       { "value": 48 },
        "h2":       { "value": 36 },
        "h3":       { "value": 32 },
        "h4":       { "value": 24 },
        "h5":       { "value": 20 },
        "h6":       { "value": 18 },
        "body":     { "value": 16 },
        "bodySm":   { "value": 14 },
        "caption":  { "value": 12 }
      },
      "fontWeight": {
        "regular":  { "value": 400 },
        "medium":   { "value": 500 },
        "semiBold": { "value": 600 }
      }
    },

    "iconSize": {
      "$description": "Standard icon dimensions",
      "xs": { "value": 12 },
      "sm": { "value": 16 },
      "md": { "value": 20 },
      "lg": { "value": 24 },
      "xl": { "value": 32 }
    }
  }
}
