      "primary": {
        "25":  { "value": "#F9FBFF" },
        "50":  { "value": "#F3F8FF" },
        "100": { "value": "#E6F0FF" },
        "200": { "value": "#C1DAFF" },
        "300": { "value": "#9BC4FF" },
        "400": { "value": "#5098FF" },
        "500": { "value": "#056CFF" },
        "600": { "value": "#0561E6" },
        "700": { "value": "#034199" },
        "800": { "value": "#023173" },
        "900": { "value": "#02204D" },
        "950": { "value": "#021A3F" }
      },
      "gray": {
        "25":  { "value": "#FCFCFC" },
        "50":  { "value": "#F9FAFB" },
        "100": { "value": "#F3F4F6" },
        "200": { "value": "#E5E7EB" },
        "300": { "value": "#D1D5DB" },
        "400": { "value": "#9CA3AF" },
        "500": { "value": "#6B7280" },
        "600": { "value": "#4B5563" },
        "700": { "value": "#374151" },
