        "800": { "value": "#991B1B" },
        "900": { "value": "#881C14" },
        "950": { "value": "#450A0A" }
      },
      "warning": {
        "25":  { "value": "#FFFCF2" },
        "50":  { "value": "#FFFAEB" },
        "100": { "value": "#FEF0C7" },
        "200": { "value": "#FEE089" },
        "300": { "value": "#FDC94C" },
        "400": { "value": "#FDB322" },
        "500": { "value": "#F79009" },
        "600": { "value": "#DB6A04" },
        "700": { "value": "#B54808" },
        "800": { "value": "#93380D" },
        "900": { "value": "#792E0E" },
        "950": { "value": "#461602" }
      },
      "success": {
        "25":  { "value": "#F3FFF8" },
        "50":  { "value": "#ECFDF3" },
        "100": { "value": "#D1FADF" },
