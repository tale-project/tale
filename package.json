{
  "name": "tale",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "services/platform",
    "services/crawler",
    "services/rag",
    "services/operator",
    "services/db",
    "services/proxy",
    "tools/cli"
  ],
  "scripts": {
    "dev": "bunx turbo run dev",
    "serve": "bunx turbo run serve",
    "build": "bunx turbo run build",
    "lint": "bunx turbo run lint",
    "lint:fix": "bunx turbo run lint:fix",
    "format": "bunx turbo run format",
    "format:check": "bunx turbo run format:check",
    "test": "bunx turbo run test",
    "test:ui": "bunx turbo run test:ui",
    "test:watch": "bunx turbo run test:watch",
    "test:coverage": "bunx turbo run test:coverage",
    "typecheck": "bunx turbo run typecheck",
    "knip": "bunx knip --fix && bunx turbo run format",
    "knip:check": "bunx knip",
    "setup": "bunx turbo run setup",
    "docker:build": "bunx turbo run docker:build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "commit": "bunx cz",
    "storybook": "bun run --filter @tale/platform storybook",
    "prepare": "bunx husky"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@ai-sdk/openai": "2.0.95",
    "@ai-sdk/provider-utils": "3.0.21",
    "@convex-dev/action-cache": "0.3.0",
    "@convex-dev/agent": "^0.3.2",
    "@convex-dev/better-auth": "0.10.13",
    "@convex-dev/persistent-text-streaming": "0.3.0",
    "@convex-dev/rate-limiter": "0.3.2",
    "@convex-dev/workflow": "0.3.2",
    "@convex-dev/workpool": "0.4.1",
    "ai": "5.0.141",
    "base64-arraybuffer": "1.0.2",
    "better-auth": "1.4.9",
    "convex": "^1.32.0",
    "convex-helpers": "0.1.114",
    "cron-parser": "5.5.0",
    "jexl": "2.3.0",
    "jose": "6.1.3",
    "lodash": "4.17.23",
    "mssql": "12.2.0",
    "mustache": "4.2.0",
    "mysql2": "3.18.2",
    "pg": "8.19.0",
    "sucrase": "^3.35.1",
    "xlsx": "0.18.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@vitest/coverage-v8": "4.0.18",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "jsdom": "28.1.0",
    "knip": "^5.83.0",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.43.0",
    "oxlint-tsgolint": "^0.15.0",
    "postcss": "8.5.6",
    "turbo": "2.8.12",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "^4.2.0"
  },
  "patchedDependencies": {
    "convex-helpers@0.1.113": "patches/convex-helpers@0.1.113.patch"
  },
  "overrides": {
    "react-is": "^19.2.4",
    "magic-string": "^0.30.17"
  }
}
