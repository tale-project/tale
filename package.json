{
  "name": "tale",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "services/platform",
    "services/crawler",
    "services/rag",
    "services/operator",
    "services/db",
    "services/proxy",
    "tools/cli"
  ],
  "scripts": {
    "dev": "bunx turbo run dev",
    "serve": "bunx turbo run serve",
    "build": "bunx turbo run build",
    "lint": "bunx turbo run lint",
    "lint:fix": "bunx turbo run lint:fix",
    "format": "bunx turbo run format",
    "format:check": "bunx turbo run format:check",
    "test": "bunx turbo run test",
    "test:ui": "bunx turbo run test:ui",
    "test:watch": "bunx turbo run test:watch",
    "test:coverage": "bunx turbo run test:coverage",
    "typecheck": "bunx turbo run typecheck",
    "knip": "bunx knip --fix && bunx turbo run format",
    "knip:check": "bunx knip",
    "setup": "bunx turbo run setup",
    "docker:build": "bunx turbo run docker:build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "commit": "bunx cz",
    "storybook": "bun run --filter @tale/platform storybook",
    "prepare": "bunx husky"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@vitest/coverage-v8": "4.1.0",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "husky": "9.1.7",
    "jsdom": "28.1.0",
    "knip": "5.86.0",
    "oxfmt": "0.32.0",
    "oxlint": "1.55.0",
    "oxlint-tsgolint": "0.16.0",
    "postcss": "8.5.8",
    "turbo": "2.8.16",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.1"
  },
  "patchedDependencies": {
    "convex-helpers@0.1.113": "patches/convex-helpers@0.1.113.patch"
  },
  "overrides": {
    "react-is": "19.2.4",
    "magic-string": "0.30.21"
  }
}
