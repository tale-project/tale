{
  "name": "tale",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/i18n",
    "packages/tale_knowledge",
    "packages/tale_shared",
    "packages/tale_telemetry",
    "packages/ui",
    "packages/webui",
    "services/platform",
    "services/web",
    "services/docs",
    "services/crawler",
    "services/rag",
    "services/db",
    "services/proxy",
    "tools/cli",
    "tools/plop"
  ],
  "scripts": {
    "dev": "bunx turbo run dev",
    "serve": "bunx turbo run serve",
    "build": "bunx turbo run build",
    "lint": "bunx turbo run lint",
    "lint:fix": "bunx turbo run lint:fix",
    "format": "oxfmt && bunx turbo run format",
    "format:check": "oxfmt --check && bunx turbo run format:check",
    "check": "bun run format:check && bunx turbo run lint typecheck test",
    "test": "bunx turbo run test",
    "test:ui": "bunx turbo run test:ui",
    "test:watch": "bunx turbo run test:watch",
    "test:coverage": "bunx turbo run test:coverage",
    "typecheck": "bunx turbo run typecheck",
    "knip": "bunx knip --fix && bunx turbo run format",
    "knip:check": "bunx knip",
    "setup": "bunx turbo run setup",
    "docker:build": "bunx turbo run docker:build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:test": "bash tests/container-smoke-test.sh",
    "docker:test:image": "bash tests/container-image-test.sh",
    "docker:test:vulnerability": "bash tests/container-vulnerability-scan.sh",
    "commit": "bunx cz",
    "storybook": "bunx turbo run storybook",
    "storybook:ui": "bun run --filter @tale/ui storybook",
    "storybook:webui": "bun run --filter @tale/webui storybook",
    "storybook:platform": "bun run --filter @tale/platform storybook",
    "gen": "bunx --bun plop --plopfile plopfile.ts",
    "gen:react-service": "bun run gen react-service",
    "gen:react-package": "bun run gen react-package",
    "gen:typescript-package": "bun run gen typescript-package",
    "gen:python-service": "bun run gen python-service",
    "gen:python-package": "bun run gen python-package",
    "gen:docker-service": "bun run gen docker-service",
    "prepare": "bunx husky"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tailwindcss/postcss": "4.2.2",
    "@tanstack/react-router": "1.168.10",
    "class-variance-authority": "0.7.1",
    "framer-motion": "12.38.0",
    "i18next": "26.0.4",
    "lucide-react": "1.8.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.72.1",
    "tailwindcss": "4.2.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-themes": "10.3.5",
    "@storybook/addon-vitest": "10.3.5",
    "@storybook/react": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@tanstack/router-plugin": "1.167.12",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/bun": "1.3.11",
    "@types/jsdom": "^28.0.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser": "4.1.4",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "husky": "9.1.7",
    "jsdom": "29.0.2",
    "knip": "6.3.1",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "plop": "4.0.1",
    "postcss": "8.5.9",
    "postcss-load-config": "6.0.1",
    "storybook": "10.3.5",
    "turbo": "2.9.5",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vitest": "4.1.4",
    "vitest-axe": "1.0.0-pre.5"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.2"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.13",
    "axios": "1.15.0",
    "brace-expansion": "4.0.1",
    "defu": "6.1.6",
    "follow-redirects": "1.16.0",
    "immutable": "3.8.3",
    "lodash-es": "4.18.1",
    "magic-string": "0.30.21",
    "react-is": "19.2.5",
    "uuid": "14.0.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "packageManager": "bun@1.3.10",
  "patchedDependencies": {
    "convex-helpers@0.1.114": "patches/convex-helpers@0.1.114.patch"
  },
  "trustedDependencies": [
    "core-js-pure",
    "esbuild"
  ]
}
