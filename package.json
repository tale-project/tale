{
  "name": "tale",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "docs",
    "packages/tale_knowledge",
    "packages/tale_shared",
    "packages/tale_telemetry",
    "services/platform",
    "services/crawler",
    "services/rag",
    "services/db",
    "services/proxy",
    "tools/cli"
  ],
  "scripts": {
    "dev": "bunx turbo run dev",
    "serve": "bunx turbo run serve",
    "build": "bunx turbo run build",
    "lint": "bunx turbo run lint",
    "lint:fix": "bunx turbo run lint:fix",
    "format": "oxfmt && bunx turbo run format",
    "format:check": "oxfmt --check && bunx turbo run format:check",
    "check": "bun run format:check && bunx turbo run lint typecheck test",
    "test": "bunx turbo run test",
    "test:ui": "bunx turbo run test:ui",
    "test:watch": "bunx turbo run test:watch",
    "test:coverage": "bunx turbo run test:coverage",
    "typecheck": "bunx turbo run typecheck",
    "knip": "bunx knip --fix && bunx turbo run format",
    "knip:check": "bunx knip",
    "setup": "bunx turbo run setup",
    "docker:build": "bunx turbo run docker:build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:test": "bash tests/container-smoke-test.sh",
    "docker:test:image": "bash tests/container-image-test.sh",
    "docker:test:vulnerability": "bash tests/container-vulnerability-scan.sh",
    "commit": "bunx cz",
    "storybook": "bun run --filter @tale/platform storybook",
    "prepare": "bunx husky"
  },
  "dependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@vitest/coverage-v8": "4.1.4",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "husky": "9.1.7",
    "jsdom": "29.0.2",
    "knip": "6.3.1",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "postcss": "8.5.9",
    "turbo": "2.9.5",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.2"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.13",
    "axios": "1.15.0",
    "brace-expansion": "1.1.13",
    "defu": "6.1.5",
    "follow-redirects": "1.16.0",
    "immutable": "3.8.3",
    "lodash-es": "4.18.0",
    "magic-string": "0.30.21",
    "react-is": "19.2.5",
    "uuid": "14.0.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "packageManager": "bun@1.3.10",
  "patchedDependencies": {
    "convex-helpers@0.1.114": "patches/convex-helpers@0.1.114.patch"
  },
  "trustedDependencies": [
    "core-js-pure",
    "esbuild"
  ]
}
