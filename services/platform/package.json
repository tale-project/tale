{
  "name": "@tale/platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "echo 'Dependencies managed by root workspace'",
    "dev": "bun scripts/dev.ts",
    "build": "bun --bun vite build",
    "start": "bun --bun vite preview",
    "lint": "bunx oxlint --type-aware",
    "lint:fix": "bunx oxlint --type-aware --fix",
    "format": "bunx oxfmt -c ../../.oxfmtrc.json",
    "format:check": "bunx oxfmt -c ../../.oxfmtrc.json --check",
    "typecheck": "bunx tsc --noEmit",
    "convex:dev": "CONVEX_AGENT_MODE=anonymous bunx convex dev",
    "convex:deploy": "CONVEX_AGENT_MODE=anonymous bunx convex deploy",
    "convex:codegen": "[ -z \"$CONVEX_DEPLOYMENT\" ] && echo 'Skipped convex codegen (no CONVEX_DEPLOYMENT)' || bunx convex codegen",
    "generate:openapi": "bun scripts/generate-openapi.ts",
    "admin:generate-password": "bun scripts/generate-admin-password.ts",
    "test": "bunx vitest --run --project server",
    "test:watch": "bunx vitest --project server",
    "test:coverage": "bunx vitest --coverage --project server",
    "test:ui": "bunx vitest --run --config vitest.ui.config.ts",
    "test:ui:watch": "bunx vitest --config vitest.ui.config.ts",
    "storybook": "bun --bun storybook dev -p 6006",
    "storybook:build": "bun --bun storybook build -o storybook-static",
    "stress-test": "bun stress-tests/run-stress-test.ts",
    "stress-test:concurrent": "bun stress-tests/scenarios/concurrent-starts.ts",
    "stress-test:sustained": "bun stress-tests/scenarios/sustained-load.ts",
    "stress-test:payload": "bun stress-tests/scenarios/payload-pressure.ts",
    "stress-test:loop": "bun stress-tests/scenarios/loop-contention.ts",
    "stress-test:scheduler": "bun stress-tests/scenarios/scheduler-overlap.ts",
    "stress-test:shard-compare": "bun stress-tests/scenarios/shard-comparison.ts"
  },
