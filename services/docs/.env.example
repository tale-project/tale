# ============================================================================
# Tale Docs (documentation site) — Environment Configuration
# ============================================================================
# Copy this file to services/docs/.env (or merge into your top-level .env)
# and fill in the values you need. The Bun server only reads `process.env`,
# so any deployment-time secret injection (Docker, systemd, K8s) works too.

# ============================================================================
# Server
# ============================================================================
# PORT: HTTP listen port (default 3002). The Dockerfile already sets this.
# HOSTNAME: Bind address (default 0.0.0.0).
# PORT=3002
# HOSTNAME=0.0.0.0
