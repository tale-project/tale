# ============================================================================
# Tale Web (marketing site) — Environment Configuration
# ============================================================================
# Copy this file to services/web/.env (or merge into your top-level .env)
# and fill in the values you need. The Bun server only reads `process.env`,
# so any deployment-time secret injection (Docker, systemd, K8s) works too.

# ============================================================================
# Server
# ============================================================================
# PORT: HTTP listen port (default 3001). The Dockerfile already sets this.
# HOSTNAME: Bind address (default 0.0.0.0).
# PORT=3001
# HOSTNAME=0.0.0.0

# ============================================================================
# OPTIONAL: Form Submissions (Discord webhook)
# ============================================================================
# The marketing site forms (Contact and Request Demo) POST to
# /api/forms/submit, which forwards a Discord embed to this webhook URL.
# If unset, /api/forms/submit returns 503 and the forms are effectively
# disabled.
#
# Create the webhook in Discord: Server Settings → Integrations → Webhooks →
# New Webhook. Copy the URL; format is:
#   https://discord.com/api/webhooks/{id}/{token}
# WEB_DISCORD_WEBHOOK_URL=
