{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "rangeStrategy": "pin",
  "automerge": false,
  "minimumReleaseAge": "90 days",
  "internalChecksFilter": "strict",
  "prCreation": "not-pending",
  "rebaseWhen": "conflicted",
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "schedule": ["before 9am on monday"],
  "timezone": "Europe/Zurich",
  "packageRules": [
    {
      "description": "Patch updates: 30 day stabilization, grouped",
      "matchUpdateTypes": ["patch", "digest", "pin"],
      "minimumReleaseAge": "30 days",
      "groupName": "patch updates"
    },
    {
      "description": "Minor updates: 60 day stabilization, grouped",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "60 days",
      "groupName": "minor updates"
    },
    {
      "description": "Pin Python Docker image to <=3.11 for RAG service",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["python"],
      "matchFileNames": ["services/rag/Dockerfile"],
      "allowedVersions": "<=3.11"
    },
    {
      "description": "Don't pin requires-python in pyproject.toml — it's a compatibility range, not a dependency pin",
      "matchManagers": ["pep621"],
      "matchDepNames": ["python"],
      "enabled": false
    },
    {
      "description": "Disable Convex-related packages (manual upgrades only)",
      "matchPackageNames": ["convex", "/^convex-/", "/^@convex-dev\\//"],
      "enabled": false
    },
    {
      "description": "Disable AI SDK packages (manual upgrades only)",
      "matchPackageNames": ["ai", "/^@ai-sdk\\//"],
      "enabled": false
    }
  ]
}
