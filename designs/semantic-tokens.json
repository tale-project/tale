          "icon":   { "$type": "color", "$value": "#F79009", "$extensions": { "mode": { "light": "#F79009", "dark": "#FDB322" } } },
          "text":   { "$type": "color", "$value": "#B54808", "$extensions": { "mode": { "light": "#B54808", "dark": "#FDC94C" } } }
        },
        "success": {
