        "secondary":   { "$type": "color", "$value": "#F9FAFB", "$extensions": { "mode": { "light": "#F9FAFB",   "dark": "#111827" } } },
        "tertiary":    { "$type": "color", "$value": "#F3F4F6", "$extensions": { "mode": { "light": "#F3F4F6",   "dark": "#1F2937" } } },
        "brand":       { "$type": "color", "$value": "#056CFF", "$extensions": { "mode": { "light": "#056CFF",   "dark": "#056CFF" } } },
        "brandSubtle": { "$type": "color", "$value": "#F3F8FF", "$extensions": { "mode": { "light": "#F3F8FF",   "dark": "#02204D" } } },
