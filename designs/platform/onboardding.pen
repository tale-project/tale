    {
      "type": "note",
      "id": "vrgbY",
      "x": 55174,
      "y": 4821,
      "width": 400,
      "height": 100,
      "content": "Prompt Library section only appears in the history sidebar after a user saves their first prompt. By default, the sidebar shows only chat history — no empty prompt library state cluttering the UI. This screen (PromptLibraryOpen) represents the state after saved prompts exist."
    },
    {
      "type": "note",
      "id": "Llv0L",
      "x": 56533,
      "y": 4793,
      "name": "note",
      "width": 320,
      "height": 80,
      "content": "Popover used for adding categories — provides clear Cancel/Add actions, consistent with filter dropdown pattern, minimal footprint without disrupting the modal layout."
    }
