                  "name": "line",
                  "fill": "#111827",
                  "content": "function calculateRevenue(deals) {",
                  "lineHeight": 1.6,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 13,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "C9Lan",
                  "name": "line",
                  "fill": "#111827",
                  "content": "  return deals.reduce((sum, deal) => {",
                  "lineHeight": 1.6,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 13,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "Nftvi",
                  "name": "line",
                  "fill": "#111827",
                  "content": "    return sum + deal.amount;",
                  "lineHeight": 1.6,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 13,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "mlOHT",
                  "name": "line",
                  "fill": "#111827",
                  "content": "  }, 0);",
                  "lineHeight": 1.6,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 13,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "8VedT",
                  "name": "line",
                  "fill": "#111827",
                  "content": "}",
                  "lineHeight": 1.6,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
        },
