                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Automation without the engineering",
                          "fontFamily": "Inter",
                          "fontSize": 28,
                          "fontWeight": "500",
                          "letterSpacing": -1.5
                        },
                        {
                          "type": "text",
                          "id": "Uzkp2",
                          "fill": "#6B7280",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Multi-step processes that run themselves — triggered by events, guided by conditions, powered by AI.\n\nDefine triggers, loops, and AI decision steps in JSON. Deploy by saving a file. From onboarding sequences to escalation chains, automations go live instantly.",
                          "lineHeight": 1.5,
                          "fontFamily": "Inter",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        }
