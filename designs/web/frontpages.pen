                  "children": [
                    {
                      "type": "text",
                      "id": "LXK0Y",
                      "fill": "#F9FAFB",
                      "content": "Deploy AI agents, not code",
                      "fontFamily": "Inter",
                      "fontSize": 28,
                      "fontWeight": "500",
                      "letterSpacing": -1.5
                    },
                    {
                      "type": "text",
                      "id": "lizpa",
                      "fill": "#9CA3AF",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Specialized AI assistants defined in a single JSON file. Give them instructions, tools, and a model — they handle the rest.\n\nNo SDKs, no deployment pipelines. Drop a file in the agents/ directory and it's live in seconds. Edit it, and changes reload instantly.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                },
