                      "descendants": {
                        "f4UMx": {
                          "gap": 12
                        },
                        "WMQpa": {
                          "content": "Is there any usage-based or seat-based pricing?",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "fontSize": 18
                        },
                        "lMDiq": {
                          "content": "No. We don't charge per user or per seat — the plan price stays the same.",
                          "width": "fill_container",
                          "fontSize": 15
                        }
                      }
                    },
                    {
                      "id": "Fr631",
                      "type": "ref",
                      "ref": "tm1lb",
                      "width": "fill_container",
                      "name": "a2",
                      "padding": [
                        32,
                        0
                      ],
                      "descendants": {
                        "f4UMx": {
                          "gap": 12
                        },
                        "WMQpa": {
                          "content": "Are there additional features in the Enterprise plan?",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "fontSize": 18
                        },
                        "lMDiq": {
                          "content": "No. All product features are available in the open source version too. Pro and Enterprise add extended support and services.",
                          "width": "fill_container",
                          "fontSize": 15
                        }
                      }
                    },
                    {
                      "id": "C7oPwc",
                      "type": "ref",
                      "ref": "tm1lb",
                      "width": "fill_container",
                      "name": "a3",
                      "padding": [
                        32,
                        0
                      ],
                      "descendants": {
                        "f4UMx": {
                          "gap": 12
                        },
                        "WMQpa": {
                          "content": "Do I have to bring my own AI models?",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "fontSize": 18
                        },
                        "lMDiq": {
                          "content": "No. You can bring your own models, but it's not required. We support most major AI providers and don't add fees on top — cloud AI model usage is priced at the rates of your chosen provider and is not included in the plans.",
                          "width": "fill_container",
                          "fontSize": 15
                        }
                      }
                    },
                    {
                      "id": "zuROC",
                      "type": "ref",
                      "ref": "tm1lb",
                      "width": "fill_container",
                      "name": "a4",
                      "padding": [
                        32,
                        0
                      ],
                      "descendants": {
                        "f4UMx": {
                          "gap": 12
                        },
                        "WMQpa": {
                          "content": "Do you also provide hardware?",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "fontSize": 18
                        },
                        "lMDiq": {
                          "content": "Yes — we support all major cloud AI providers, so you can use your preferred provider while benefiting from better pricing, higher uptime, and usage-based billing.",
                          "width": "fill_container",
                          "fontSize": 15
                        }
                      }
                    },
                    {
                      "id": "BXZXH",
                      "type": "ref",
                      "ref": "tm1lb",
                      "width": "fill_container",
                      "name": "a5",
                      "padding": [
                        32,
                        0
                      ],
                      "descendants": {
                        "f4UMx": {
                          "gap": 12
                        },
                        "WMQpa": {
                          "content": "Do you also provide hardware?",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "fontSize": 18
                        },
                        "lMDiq": {
                          "content": "Yes, we can also provide hardware (rental, leasing, purchase, etc.). Just mention it when you contact us.",
                          "width": "fill_container",
                          "fontSize": 15
                        }
                      }
                    },
                    {
                      "id": "Q51Na",
                      "type": "ref",
                      "ref": "tm1lb",
                      "width": "fill_container",
                      "name": "a6",
                      "padding": [
                        32,
                        0
                      ],
                      "descendants": {
                        "f4UMx": {
                          "gap": 12
                        },
                        "WMQpa": {
                          "content": "Can I use my own hardware and AI models?",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "fontSize": 18
                        },
                        "lMDiq": {
                          "content": "Yes. We're hardware- and model-agnostic, so you're free to use your own.",
                          "width": "fill_container",
                          "fontSize": 15
                        }
                      }
                    },
                    {
                      "id": "SxgbF",
                      "type": "ref",
                      "ref": "tm1lb",
                      "width": "fill_container",
                      "name": "a7",
                      "padding": [
                        32,
                        0
                      ],
                      "descendants": {
                        "f4UMx": {
                          "gap": 12
                        },
                        "WMQpa": {
                          "content": "Do you offer custom AI model training?",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "fontSize": 18
                        },
                        "lMDiq": {
                          "content": "Yes. We train and fine-tune custom models for clients. If you're interested, bring it up in the demo call.",
                          "width": "fill_container",
                          "fontSize": 15
                        }
                      }
                    },
