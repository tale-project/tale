                    0
                  ],
                  "fill": "#0A0A0B",
                  "stroke": {
                    "align": "inside",
                    "thickness": {
                      "bottom": 1
                    },
                    "fill": "#27272A"
                  },
                  "descendants": {
                    "f4UMx": {
                      "gap": 12
                    },
                    "WMQpa": {
                      "content": "Do you also provide hardware?",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "fontSize": 18,
                      "fill": "#F9FAFB"
                    },
                    "VXfXA": {
                      "fill": {
                        "type": "color",
                        "color": "#0A0A0B",
                        "enabled": false
