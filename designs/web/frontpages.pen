                      "bottom": 1
                    },
                    "fill": "#27272A"
                  },
                  "descendants": {
                    "f4UMx": {
                      "gap": 12
                    },
                    "WMQpa": {
                      "content": "Is there any usage-based or seat-based pricing?",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "fontSize": 18,
                      "fill": "#F9FAFB"
                    },
                    "VXfXA": {
                      "fill": {
                        "type": "color",
                        "color": "#0A0A0B",
                        "enabled": false
                      }
                    },
                    "lMDiq": {
                      "content": "No. We don't charge per user or per seat — the plan price stays the same.",
                      "width": "fill_container",
                      "fontSize": 15,
                      "fill": "#9CA3AF"
                    }
                  }
                },
                {
                  "id": "r7zd9H",
                  "type": "ref",
                  "ref": "tm1lb",
                  "width": "fill_container",
                  "name": "a2",
                  "padding": [
                    32,
                    0
                  ],
                  "fill": "#0A0A0B",
                  "stroke": {
                    "align": "inside",
                    "thickness": {
                      "bottom": 1
                    },
                    "fill": "#27272A"
                  },
                  "descendants": {
                    "f4UMx": {
                      "gap": 12
                    },
                    "WMQpa": {
                      "content": "Are there additional features in the Enterprise plan?",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "fontSize": 18,
                      "fill": "#F9FAFB"
                    },
                    "VXfXA": {
                      "fill": {
                        "type": "color",
                        "color": "#0A0A0B",
                        "enabled": false
                      }
                    },
                    "lMDiq": {
                      "content": "No. All product features are available in the open source version too. Pro and Enterprise add extended support and services.",
                      "width": "fill_container",
                      "fontSize": 15,
                      "fill": "#9CA3AF"
                    }
                  }
                },
                {
                  "id": "JY4yg",
                  "type": "ref",
                  "ref": "tm1lb",
                  "width": "fill_container",
                  "name": "a3",
                  "padding": [
                    32,
                    0
                  ],
                  "fill": "#0A0A0B",
                  "stroke": {
                    "align": "inside",
                    "thickness": {
                      "bottom": 1
                    },
                    "fill": "#27272A"
                  },
                  "descendants": {
                    "f4UMx": {
                      "gap": 12
                    },
                    "WMQpa": {
                      "content": "Do I have to bring my own AI models?",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "fontSize": 18,
                      "fill": "#F9FAFB"
                    },
                    "VXfXA": {
                      "fill": {
                        "type": "color",
                        "color": "#0A0A0B",
                        "enabled": false
                      }
                    },
                    "lMDiq": {
                      "content": "No. You can bring your own models, but it's not required. We support most major AI providers and don't add fees on top — cloud AI model usage is priced at the rates of your chosen provider and is not included in the plans.",
                      "width": "fill_container",
                      "fontSize": 15,
                      "fill": "#9CA3AF"
                    }
                  }
                },
                {
                  "id": "p7vBR",
                  "type": "ref",
                  "ref": "tm1lb",
                  "width": "fill_container",
                  "name": "a4",
                  "padding": [
                    32,
                    0
                  ],
                  "fill": "#0A0A0B",
                  "stroke": {
                    "align": "inside",
                    "thickness": {
                      "bottom": 1
                    },
                    "fill": "#27272A"
                  },
                  "descendants": {
                    "f4UMx": {
                      "gap": 12
                    },
                    "WMQpa": {
                      "content": "Do you also provide hardware?",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "fontSize": 18,
                      "fill": "#F9FAFB"
                    },
                    "VXfXA": {
                      "fill": {
                        "type": "color",
                        "color": "#0A0A0B",
                        "enabled": false
                      }
                    },
                    "lMDiq": {
                      "content": "Yes — we support all major cloud AI providers, so you can use your preferred provider while benefiting from better pricing, higher uptime, and usage-based billing.",
                      "width": "fill_container",
                      "fontSize": 15,
                      "fill": "#9CA3AF"
                    }
                  }
                },
                {
                  "id": "oByKW",
                  "type": "ref",
                  "ref": "tm1lb",
                  "width": "fill_container",
                  "name": "a5",
                  "padding": [
