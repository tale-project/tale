                  "id": "EZcL2",
                  "name": "line",
                  "fill": "#111827",
                  "content": "function calculateRevenue(deals) {",
                  "lineHeight": 1.6,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 13,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "t2eEH",
                  "name": "line",
                  "fill": "#111827",
                  "content": "  return deals.reduce((sum, deal) => {",
                  "lineHeight": 1.6,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 13,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "c6ukWZ",
                  "name": "line",
                  "fill": "#111827",
                  "content": "    return sum + deal.amount;",
                  "lineHeight": 1.6,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 13,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "NksgQ",
                  "name": "line",
                  "fill": "#111827",
                  "content": "  }, 0);",
                  "lineHeight": 1.6,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 13,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "uhQGv",
                  "name": "line",
                  "fill": "#111827",
                  "content": "}",
                  "lineHeight": 1.6,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
        },
