                  },
                  "layout": "vertical",
                  "children": [
                    {
                      "id": "dTEM8",
                      "type": "ref",
                      "ref": "tm1lb",
                      "width": "fill_container",
                      "name": "acc5",
                      "fill": "#111113",
                      "stroke": {
                        "align": "inside",
                        "thickness": {
                          "bottom": 1
                        },
                        "fill": "#27272A"
                      },
                      "descendants": {
                        "WMQpa": {
                          "content": "Is there any usage-based or seat-based pricing?",
                          "letterSpacing": -1,
                          "fill": "#F9FAFB"
                        },
                        "UiZbe": {
                          "stroke": {
                            "align": "center",
                            "thickness": 2,
                            "join": "round",
                            "cap": "round",
                            "fill": "#9CA3AF"
                          }
                        },
                        "lMDiq": {
                          "content": "No. We don't charge per user or per seat — the plan price stays the same.",
                          "fill": "#9CA3AF"
                        }
                      }
                    },
                    {
                      "id": "vWqf3",
                      "type": "ref",
                      "ref": "tm1lb",
                      "width": "fill_container",
                      "name": "acc6",
                      "fill": "#111113",
                      "stroke": {
                        "align": "inside",
                        "thickness": {
                          "bottom": 1
                        },
                        "fill": "#27272A"
                      },
                      "descendants": {
                        "WMQpa": {
                          "content": "Are there additional features in the Enterprise plan?",
                          "letterSpacing": -1,
                          "fill": "#F9FAFB"
                        },
                        "UiZbe": {
                          "stroke": {
                            "align": "center",
                            "thickness": 2,
                            "join": "round",
                            "cap": "round",
                            "fill": "#9CA3AF"
                          }
                        },
                        "lMDiq": {
                          "content": "No. All product features are available in the open source version too. Pro and Enterprise add extended support and services.",
                          "fill": "#9CA3AF"
                        }
                      }
                    },
                    {
                      "id": "P2U0z",
                      "type": "ref",
                      "ref": "tm1lb",
                      "width": "fill_container",
                      "name": "acc7",
                      "fill": "#111113",
                      "stroke": {
                        "align": "inside",
                        "thickness": {
                          "bottom": 1
                        },
                        "fill": "#27272A"
                      },
                      "descendants": {
                        "f4UMx": {
                          "flipX": false,
                          "flipY": false,
                          "width": "fill_container",
                          "height": "fit_content",
                          "x": 20,
                          "y": 20
                        },
                        "WMQpa": {
                          "content": "Do I have to bring my own AI models?",
                          "letterSpacing": -1,
                          "fill": "#F9FAFB"
                        },
                        "UiZbe": {
                          "stroke": {
                            "align": "center",
                            "thickness": 2,
                            "join": "round",
                            "cap": "round",
                            "fill": "#9CA3AF"
                          }
                        },
                        "lMDiq": {
                          "content": "No. You can bring your own models, but it's not required. We support most major AI providers and don't add fees on top — cloud AI model usage is priced at the rates of your chosen provider and is not included in the plans.",
                          "fill": "#9CA3AF"
                        }
                      }
                    },
                    {
                      "id": "SAHhx",
                      "type": "ref",
                      "ref": "tm1lb",
                      "width": "fill_container",
                      "name": "acc1",
                      "fill": "#111113",
                      "stroke": {
                        "align": "inside",
                        "thickness": {
                          "bottom": 1
                        },
                        "fill": "#27272A"
                      },
                      "descendants": {
                        "WMQpa": {
                          "content": "Do you also provide hardware?",
                          "letterSpacing": -1,
                          "fill": "#F9FAFB"
                        },
                        "UiZbe": {
                          "stroke": {
                            "align": "center",
                            "thickness": 2,
                            "join": "round",
                            "cap": "round",
                            "fill": "#9CA3AF"
                          }
                        },
                        "lMDiq": {
                          "content": "Yes — we support all major cloud AI providers, so you can use your preferred provider while benefiting from better pricing, higher uptime, and usage-based billing.",
                          "fill": "#9CA3AF"
                        }
                      }
                    },
                    {
                      "id": "fOQ4N",
                      "type": "ref",
                      "ref": "tm1lb",
                      "width": "fill_container",
                      "name": "acc2",
                      "fill": "#111113",
                      "stroke": {
                        "align": "inside",
                        "thickness": {
                          "bottom": 1
                        },
                        "fill": "#27272A"
                      },
                      "descendants": {
                        "WMQpa": {
                          "content": "Do you also provide hardware?",
                          "letterSpacing": -1,
                          "fill": "#F9FAFB"
                        },
                        "UiZbe": {
                          "stroke": {
                            "align": "center",
                            "thickness": 2,
                            "join": "round",
                            "cap": "round",
                            "fill": "#9CA3AF"
                          }
                        },
                        "lMDiq": {
                          "content": "Yes, we can also provide hardware (rental, leasing, purchase, etc.). Just mention it when you contact us.",
                          "fill": "#9CA3AF"
                        }
                      }
                    },
                    {
                      "id": "vAiuw",
                      "type": "ref",
                      "ref": "tm1lb",
                      "width": "fill_container",
                      "name": "acc3",
                      "fill": "#111113",
                      "stroke": {
                        "align": "inside",
                        "thickness": {
                          "bottom": 1
                        },
                        "fill": "#27272A"
                      },
                      "descendants": {
                        "WMQpa": {
                          "content": "Can I use my own hardware and AI models?",
                          "letterSpacing": -1,
                          "fill": "#F9FAFB"
                        },
                        "UiZbe": {
                          "stroke": {
                            "align": "center",
                            "thickness": 2,
                            "join": "round",
                            "cap": "round",
                            "fill": "#9CA3AF"
                          }
                        },
                        "lMDiq": {
                          "content": "Yes. We're hardware- and model-agnostic, so you're free to use your own.",
                          "fill": "#9CA3AF"
                        }
                      }
                    },
                    {
                      "id": "ZgMq1",
                      "type": "ref",
                      "ref": "tm1lb",
                      "width": "fill_container",
                      "name": "acc4",
                      "fill": "#111113",
                      "stroke": {
                        "align": "inside",
                        "thickness": {
                          "bottom": 1
                        },
                        "fill": "#27272A"
                      },
                      "descendants": {
                        "WMQpa": {
                          "content": "Do you offer custom AI model training?",
                          "letterSpacing": -1,
                          "fill": "#F9FAFB"
                        },
                        "UiZbe": {
                          "stroke": {
                            "align": "center",
                            "thickness": 2,
                            "join": "round",
                            "cap": "round",
                            "fill": "#9CA3AF"
                          }
                        },
                        "lMDiq": {
                          "content": "Yes. We train and fine-tune custom models for clients. If you're interested, bring it up in the demo call.",
                          "fill": "#9CA3AF"
                        }
                      }
                    },
