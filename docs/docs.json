{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Tale",
  "description": "The Sovereign AI Platform — Local AI models, agents, skills, and automations — on your own infrastructure, connected to your data. ISO 27001 & SOC 2 certified. Swiss-based.",
  "theme": "maple",
  "colors": {
    "primary": "#056CFF",
    "light": "#056CFF",
    "dark": "#5098FF"
  },
  "logo": {
    "light": "/images/logo-text-black.svg",
    "dark": "/images/logo-text-white.svg",
    "href": "https://tale.dev/"
  },
  "favicon": {
    "light": "/images/favicon-black.png",
    "dark": "/images/favicon-white.png"
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "heading": { "family": "Inter", "weight": 600 },
    "body": { "family": "Inter", "weight": 400 }
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "color": { "light": "#FFFFFF", "dark": "#0A0A0A" }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": { "light": "github-light", "dark": "github-dark-default" }
    }
  },
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "global": {
          "anchors": [
            { "anchor": "GitHub", "icon": "github", "href": "https://github.com/tale-project/tale" },
            { "anchor": "API reference", "icon": "code", "href": "/develop/api-reference" }
          ]
        },
        "groups": [
          {
            "group": "Start here",
            "pages": ["index"]
          },
          {
            "group": "Use Tale",
            "pages": [
              "use/getting-started",
              "use/preferences",
              {
                "group": "Chat",
                "pages": [
                  "use/chat/basics",
                  "use/chat/attachments",
                  "use/chat/agents-in-chat",
                  "use/chat/arena-mode"
                ]
              },
              {
                "group": "Workspace",
                "pages": [
                  "use/workspace/knowledge-base",
                  "use/workspace/conversations",
                  "use/workspace/approvals",
                  "use/workspace/canvas",
                  "use/workspace/prompt-library",
                  "use/workspace/document-comparison"
                ]
              }
            ]
          },
          {
            "group": "Build with Tale",
            "pages": [
              "build/overview",
              {
                "group": "Agents",
                "pages": [
                  "build/agents/concepts",
                  "build/agents/create",
                  "build/agents/versions"
                ]
              },
              {
                "group": "Automations",
                "pages": [
                  "build/automations/concepts",
                  "build/automations/workflows",
                  "build/automations/triggers",
                  "build/automations/execution-logs"
                ]
              },
              {
                "group": "Knowledge",
                "pages": [
                  "build/knowledge/structured-data",
                  "build/knowledge/crawling"
                ]
              },
              {
                "group": "Integrations",
                "pages": [
                  "build/integrations/overview",
                  "build/integrations/providers"
                ]
              }
            ]
          },
          {
            "group": "Administer",
            "pages": [
              "admin/members-and-roles",
              "admin/teams",
              "admin/authentication",
              "admin/providers",
              "admin/branding",
              "admin/governance",
              "admin/usage-analytics"
            ]
          },
          {
            "group": "Operate",
            "pages": [
              "operate/overview",
              {
                "group": "Deployment",
                "pages": [
                  "operate/deployment/production",
                  "operate/deployment/container-architecture"
                ]
              },
              {
                "group": "Configuration",
                "pages": [
                  "operate/configuration/environment-reference",
                  "operate/configuration/retention"
                ]
              },
              {
                "group": "Observability",
                "pages": [
                  "operate/observability/operations",
                  "operate/observability/troubleshooting"
                ]
              },
              {
                "group": "Security",
                "pages": ["operate/security/advisories"]
              },
              {
                "group": "Release notes",
                "pages": [
                  "operate/release-notes/format",
                  "operate/release-notes/v0.2.34-split-convex"
                ]
              }
            ]
          },
          {
            "group": "Develop",
            "pages": [
              "develop/api-reference",
              "develop/webhooks",
              "develop/ai-assisted-development",
              "develop/contributing-docker"
            ]
          },
          {
            "group": "Legal",
            "pages": [
              "legal/privacy-policy",
              "legal/terms-of-service",
              "legal/data-processing-agreement"
            ]
          }
        ]
      },
