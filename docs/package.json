{
  "name": "@tale/docs",
  "version": "0.0.0",
  "private": true,
  "description": "Tale Mintlify documentation site.",
  "type": "module",
  "scripts": {
    "format": "bunx oxfmt -c ../.oxfmtrc.json",
    "format:check": "bunx oxfmt -c ../.oxfmtrc.json --check",
    "dev": "mintlify dev",
    "build": "mintlify build",
    "lint:frontmatter": "bun run scripts/lint-frontmatter.ts",
    "lint:terminology": "bun run scripts/lint-terminology.ts",
    "lint:broken-links": "mintlify broken-links",
    "lint": "bun run lint:frontmatter && bun run lint:terminology && bun run lint:broken-links"
  }
}
