{
  "name": "@tale/docs",
  "version": "0.0.0",
  "private": true,
  "description": "Tale Mintlify documentation site.",
  "type": "module",
  "scripts": {
    "format": "bunx oxfmt -c ../.oxfmtrc.json",
    "format:check": "bunx oxfmt -c ../.oxfmtrc.json --check",
    "dev": "bunx mintlify dev",
    "build": "bunx mintlify build",
    "lint:oxlint": "bunx oxlint --type-aware",
    "lint:broken-links": "bunx mintlify broken-links --check-anchors",
    "lint": "bun run lint:oxlint && bun run lint:broken-links",
    "test": "bunx vitest --run",
    "test:watch": "bunx vitest"
  }
}
