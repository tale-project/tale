  "antiPatterns": {
    "_note": "Named patterns the test suite enforces or that reviewers flag on sight. Documented here for cross-reference; the test logic lives in services/docs/tests/.",
    "shared": [
      {
        "name": "Stub Closing",
        "test": "closing-paragraph.test.ts",
        "fix": "Rename closing section; replace bare link list with recap paragraph + contextualised link."
      },
      {
        "name": "Naked List",
        "test": null,
        "fix": "Add prose paragraph before list; the heading owns a paragraph, not a list."
      },
      {
        "name": "Marketing Drift",
        "test": null,
        "fix": "Strike the marketing softener (simply, easy, powerful, seamless, discover, …)."
      },
      {
        "name": "Status Chatter",
        "test": null,
        "fix": "Delete `Updated:`, `New in v1.6:`, `TODO:`, `Note that…`."
      },
      {
        "name": "Stub Page",
        "test": null,
        "fix": "Merge with parent or expand."
      }
    ],
    "de": [
      {
        "name": "Passive present (Wird X…)",
        "test": null,
        "fix": "Use active verb: Speichert… not Wird gespeichert…"
      },
      {
        "name": "Sentence-final erfolgreich",
        "test": null,
        "fix": "Strike erfolgreich from confirmation toasts."
      },
      {
        "name": "Damit-Opener",
        "test": null,
        "fix": "Verb-first construction: Entfernt… not Damit werden…"
      },
      {
        "name": "Compound Stack",
        "test": null,
        "fix": "Split compounds longer than three roots."
      },
      {
        "name": "Sie-Slip",
        "test": "terminology.test.ts (formalPronouns)",
        "fix": "Rewrite to du-form."
      },
      {
        "name": "English noun in prose",
        "test": "loanword.test.ts",
        "fix": "Use the native term from translateBucket.de."
      }
    ],
    "fr": [
      {
        "name": "Marketing softener (Découvre, N'hésite pas à, …)",
        "test": null,
        "fix": "Strike or replace with imperative."
      },
      {
        "name": "Stacked nominal phrase",
        "test": null,
        "fix": "Replace de-de-de chains with relative clause."
      },
      {
        "name": "Vous-Slip",
        "test": "terminology.test.ts (formalPronouns)",
        "fix": "Rewrite to tu-form."
      },
      {
        "name": "English noun in prose",
        "test": "loanword.test.ts",
        "fix": "Use the native term from translateBucket.fr."
      },
      {
        "name": "Wrong apostrophe in fr.json",
        "test": null,
        "fix": "ASCII ' in JSON; typographic ' only in docs prose."
      },
      {
        "name": "Missing NBSP before colon",
        "test": null,
        "fix": "Insert U+00A0 before :;!?% in prose; preserve in JSON."
      }
    ]
  },

  "version": "2.0.0",
  "_versionNote": "v2.0.0 — restructured glossary (categorised inventory, anti-patterns catalogue, per-locale style conventions, alwaysEnglish/establishedLoanwords/translateBucket separation). v1.x was the original flat enToLocale+formalPronouns shape; the existing tests read enToLocale, formalPronouns, and translateBucket — the new sections are documented projections for future tooling and human reference."
