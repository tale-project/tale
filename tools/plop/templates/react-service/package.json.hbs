{
  "name": "@tale/{{kebabCase name}}",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "{{description}}",
  "scripts": {
    "setup": "echo 'Dependencies managed by root workspace'",
    "dev": "bun --bun vite",
    "build": "bun --bun vite build",
    "start": "bun server.ts",
    "lint": "bunx oxlint --type-aware",
    "lint:fix": "bunx oxlint --type-aware --fix",
    "typecheck": "bunx tsc --noEmit",
    "test": "bunx vitest --run --passWithNoTests",
    "test:watch": "bunx vitest",
    "test:coverage": "bunx vitest --coverage --passWithNoTests"{{#if storybook}},
    "storybook": "bunx --bun storybook dev -p 6006",
    "storybook:build": "bunx --bun storybook build -o storybook-static"{{/if}}
  },
  "dependencies": {
    "@tale/seo": "workspace:*",
    "@tale/ui": "workspace:*",
    "@tale/webui": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "1.3.11"
  }
}
